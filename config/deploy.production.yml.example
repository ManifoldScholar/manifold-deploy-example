# =============================================================================
# Instance-specific overrides (untracked)
# =============================================================================
#
# Copy this file to config/deploy.<destination>.yml (e.g. deploy.production.yml)
# and fill in your values. This deep-merges on top of deploy.yml.
#
# Then run all Kamal commands with -d <destination>:
#   kamal setup -d production
#   kamal deploy -d production
#   etc.
#
# Secrets go in .kamal/secrets.<destination> (e.g. .kamal/secrets.production)
#
# =============================================================================

# -- Change these two values -------------------------------------------------
<% server_ip = "203.0.113.1" %>
<% domain    = "manifold.example.com" %>
# -----------------------------------------------------------------------------

<% client_url = "https://#{domain}" %>

x-server-ip:  &server-ip  "<%= server_ip %>"
x-domain:     &domain      "<%= domain %>"
x-client-url: &client-url  "<%= client_url %>"

servers:
  web:
    hosts:
      - *server-ip
  worker:
    hosts:
      - *server-ip

proxy:
  host: *domain

env:
  clear:
    DOMAIN: *domain
    CLIENT_BROWSER_API_URL: *client-url
    UPLOAD_CDN_HOST: *client-url

accessories:
  db:
    host: *server-ip
  storage:
    host: *server-ip
    proxy:
      host: *domain
  client:
    host: *server-ip
    proxy:
      host: *domain
    env:
      clear:
        DOMAIN: *domain
        CLIENT_URL: *client-url
        CLIENT_BROWSER_API_URL: *client-url
        CLIENT_BROWSER_API_CABLE_URL: *client-url
