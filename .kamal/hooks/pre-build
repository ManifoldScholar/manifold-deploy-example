#!/usr/bin/env ruby
#
# Pre-build hook for Kamal deployments.
#
# Builds, pushes, and pre-pulls the client image on the server. Kamal only
# builds the primary (API) image. The client runs as an accessory, so we
# handle its image here. Tagged with the git hash of the last client commit
# to skip unnecessary rebuilds.
#
# Kamal's local registry SSH tunnel is only active while pulling the primary
# image. By the time accessories boot, the tunnel is closed. We open our own
# temporary tunnel to pull the client image.

require "bundler/setup"
$stdout.reopen("/dev/tty", "w")
$stderr.reopen("/dev/tty", "w")
require_relative "../../lib/manifold/ui"
require_relative "../../lib/manifold/config"

CLIENT_IMAGE = "localhost:5555/manifold-client"
REGISTRY_PORT = 5555

def server
  @server ||= ENV.fetch("KAMAL_HOSTS").split(",").first
end

# Match the SSH user Kamal connects as (ssh.user in config/deploy.yml,
# defaulting to root). These SSH calls bypass Kamal's own connection, so we
# resolve the user ourselves rather than hardcoding root.
def ssh_user
  dest = ENV["KAMAL_DESTINATION"]
  @ssh_user ||= dest ? Manifold::Config.resolve_host(dest)[1] : "root"
end

def run(*cmd)
  system(*cmd, exception: true)
end

def image_exists_on_server?(image_ref)
  system("ssh", "#{ssh_user}@#{server}", "docker image inspect #{image_ref}",
    out: File::NULL, err: File::NULL)
end

def client_tag
  @client_tag ||= `git -C manifold log -1 --format=%h -- client`.strip
end

def ensure_latest_tag_on_server
  unless image_exists_on_server?("#{CLIENT_IMAGE}:latest")
    Manifold::UI.step "Tagging #{client_tag} as latest on #{server}..."
    run "ssh", "#{ssh_user}@#{server}",
      "docker tag #{CLIENT_IMAGE}:#{client_tag} #{CLIENT_IMAGE}:latest"
  end
end

def ensure_client_image
  if image_exists_on_server?("#{CLIENT_IMAGE}:#{client_tag}")
    Manifold::UI.step "Client image #{client_tag} already exists on #{server}, skipping build."
    ensure_latest_tag_on_server
    return
  end

  Manifold::UI.step "Building Manifold client image (#{client_tag})..."
  run "docker", "build",
    "--progress=plain",
    "--platform", "linux/amd64",
    "-t", "#{CLIENT_IMAGE}:#{client_tag}",
    "-t", "#{CLIENT_IMAGE}:latest",
    "--target", "production",
    "-f", "manifold/client/Dockerfile",
    "manifold/client"

  Manifold::UI.step "Pushing client image to local registry..."
  run "docker", "push", "#{CLIENT_IMAGE}:#{client_tag}"
  run "docker", "push", "#{CLIENT_IMAGE}:latest"

  Manifold::UI.step "Pre-pulling client image on #{server}..."
  run "ssh", "-R", "#{REGISTRY_PORT}:localhost:#{REGISTRY_PORT}", "#{ssh_user}@#{server}",
    "docker pull #{CLIENT_IMAGE}:#{client_tag} && " \
    "docker tag #{CLIENT_IMAGE}:#{client_tag} #{CLIENT_IMAGE}:latest"

  Manifold::UI.step "Client image ready."
end

# ---------------------------------------------------------------------------

ensure_client_image
