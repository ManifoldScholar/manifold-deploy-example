#!/usr/bin/env ruby
#
# Pre-build hook for Kamal deployments. Handles two things:
#
# 1. Client image: Build, push to local registry, and pre-pull on the server.
#    Kamal only builds the primary (API) image. The client runs as an accessory,
#    so we handle its image here. Tagged with the git hash of the last client
#    commit to skip unnecessary rebuilds.
#
# 2. API "latest" tag: The worker accessory references the API image as
#    "localhost:5555/manifold-api:latest", but kamal only pulls it with a
#    commit-specific tag. We tag whatever API image exists on the server as
#    "latest" so the worker can find it.
#
# Kamal's local registry SSH tunnel is only active while pulling the primary
# image. By the time accessories boot, the tunnel is closed. We open our own
# temporary tunnel to pull the client image.
#
# Note: Kamal captures hook stdout/stderr, so output goes to /dev/tty.

require_relative "lib/deploy_helpers"

CLIENT_IMAGE = "localhost:5555/manifold-client"
API_IMAGE = "localhost:5555/manifold-api"

# ---------------------------------------------------------------------------

def client_tag
  @client_tag ||= `git -C manifold log -1 --format=%h -- client`.strip
end

def ensure_client_image
  if image_exists_on_server?("#{CLIENT_IMAGE}:#{client_tag}")
    tty "==> Client image #{client_tag} already exists on #{server}, skipping build."
    return
  end

  tty "==> Building Manifold client image (#{client_tag})..."
  run "docker", "build",
    "--progress=plain",
    "--platform", "linux/amd64",
    "-t", "#{CLIENT_IMAGE}:#{client_tag}",
    "-t", "#{CLIENT_IMAGE}:latest",
    "--target", "production",
    "-f", "manifold/client/Dockerfile",
    "manifold/client"

  tty "==> Pushing client image to local registry..."
  run "docker", "push", "#{CLIENT_IMAGE}:#{client_tag}"
  run "docker", "push", "#{CLIENT_IMAGE}:latest"

  tty "==> Pre-pulling client image on #{server}..."
  run "ssh", "-R", "#{REGISTRY_PORT}:localhost:#{REGISTRY_PORT}", "root@#{server}",
    "docker pull #{CLIENT_IMAGE}:#{client_tag} && " \
    "docker tag #{CLIENT_IMAGE}:#{client_tag} #{CLIENT_IMAGE}:latest"

  tty "==> Client image ready."
end

def ensure_api_latest_tag
  existing_tag = ssh_capture(
    "docker images #{API_IMAGE} --format '{{.Tag}}' | grep -v latest | head -1"
  )

  if existing_tag.empty?
    tty "==> No API image on #{server} yet (first deploy)."
    tty "    After setup, run: kamal accessory reboot worker -d <destination>"
  else
    tty "==> Tagging API image (#{existing_tag}) as 'latest' on #{server}..."
    ssh "docker tag #{API_IMAGE}:#{existing_tag} #{API_IMAGE}:latest"
  end
end

# ---------------------------------------------------------------------------

ensure_client_image
ensure_api_latest_tag