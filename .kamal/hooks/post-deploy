#!/usr/bin/env ruby
#
# Post-deploy hook.
#
# The client runs as an accessory, so `kamal deploy` (which only updates the
# app's server roles) leaves it running the old image. Reboot it so it pulls
# and runs the latest published client image.
#
# Images come from a real registry (ghcr.io by default), so a plain
# `kamal accessory reboot` works — it re-pulls and re-registers with the proxy.
# (The old local-registry setup couldn't do this because its SSH tunnel was
# already closed by post-deploy; that constraint is gone.)

require "bundler/setup"
$stdout.reopen("/dev/tty", "w")
$stderr.reopen("/dev/tty", "w")
require_relative "../../lib/manifold/ui"

dest = ENV["KAMAL_DESTINATION"]
dest_flag = dest ? ["-d", dest] : []

Manifold::UI.step "Rebooting client accessory to pick up the latest image..."
system("kamal", "accessory", "reboot", "client", *dest_flag, exception: true)
Manifold::UI.step "Client accessory updated."
