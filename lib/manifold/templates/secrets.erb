# =============================================================================
# Manifold Deployment Secrets — generated by bin/deploy configure
# =============================================================================
#
# Regenerate with: bin/deploy configure
#
# This file supports variable substitution ($VAR) and command substitution
# ($(command)), so derived values are set automatically.
# =============================================================================

# -- Rails Secret Key ---------------------------------------------------------
SECRET_KEY_BASE=<%= s.secret_key_base %>

# Manifold reads RAILS_SECRET_KEY in config/secrets.yml; Rails also honors
# SECRET_KEY_BASE directly. Setting both ensures compatibility.
RAILS_SECRET_KEY=$SECRET_KEY_BASE

<% if s.local_database? -%>
# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_PASSWORD=<%= s.postgres_password %>

# Database credentials (derived from POSTGRES_PASSWORD)
RAILS_DB_PASS=$POSTGRES_PASSWORD
RAILS_CACHE_DB_PASS=$POSTGRES_PASSWORD
PGPASSWORD=$POSTGRES_PASSWORD
<% else -%>
# -- External Database --------------------------------------------------------
RAILS_DB_PASS=<%= s.db_password %>
RAILS_CACHE_DB_PASS=$RAILS_DB_PASS
PGPASSWORD=$RAILS_DB_PASS
<% end -%>
<% if s.minio_storage? -%>

# -- MinIO / S3 Storage ------------------------------------------------------
MINIO_ROOT_USER=manifold
MINIO_ROOT_PASSWORD=<%= s.minio_root_password %>

# S3 credentials (derived from MinIO credentials)
S3_ACCESS_KEY_ID=$MINIO_ROOT_USER
S3_SECRET_ACCESS_KEY=$MINIO_ROOT_PASSWORD
<% elsif s.s3_storage? -%>

# -- External S3 Storage -----------------------------------------------------
S3_ACCESS_KEY_ID=<%= s.s3_access_key_id %>
S3_SECRET_ACCESS_KEY=<%= s.s3_secret_access_key %>
<% end -%>
