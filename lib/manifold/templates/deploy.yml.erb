# =============================================================================
# Instance-specific overrides — generated by bin/deploy configure
# =============================================================================
#
# This file deep-merges on top of deploy.yml.
# Regenerate with: bin/deploy configure -d <%= s.dest %>
#
# All Kamal commands require -d <%= s.dest %>:
#   bin/deploy setup -d <%= s.dest %>
#   bin/deploy up -d <%= s.dest %>
#
# Secrets: .kamal/secrets.<%= s.dest %>
#
# bin/deploy configure: <%= s.to_settings_comment %>
# =============================================================================

x-server-ip:  &server-ip  "<%= s.server_ip %>"
x-domain:     &domain      "<%= s.effective_domain %>"
x-client-url: &client-url  "<%= s.client_url %>"

servers:
  web:
    hosts:
      - *server-ip
<% if s.minio_storage? -%>
    cmd: bash -c "bin/ensure-bucket && bin/ensure-db && bin/rails manifold:upgrade && exec bin/puma -C config/puma.rb"
<% end -%>
    options:
      network-alias: <%= s.svc %>-api
<% if s.local_storage? -%>
      volume: <%= s.dest %>-uploads:/srv/app/public/system
<% end -%>
  worker:
    hosts:
      - *server-ip
<% if s.local_storage? -%>
    options:
      volume: <%= s.dest %>-uploads:/srv/app/public/system
<% end -%>

proxy:
  host: *domain

env:
  clear:
<% if s.ssl_disabled? -%>
    SSL_ENABLED: "false"
<% end -%>
    DOMAIN: *domain
<% if s.external_database? -%>
    RAILS_DB_HOST: "<%= s.db_host %>"
    RAILS_DB_PORT: "<%= s.db_port %>"
    RAILS_DB_USER: "<%= s.db_user %>"
    RAILS_DB_NAME: "<%= s.db_name %>"
    RAILS_CACHE_DB_HOST: "<%= s.db_host %>"
    RAILS_CACHE_DB_PORT: "<%= s.db_port %>"
    RAILS_CACHE_DB_USER: "<%= s.db_user %>"
    RAILS_CACHE_DB_NAME: "<%= s.db_name %>_cache"
    PGHOST: "<%= s.db_host %>"
    PGPORT: "<%= s.db_port %>"
    PGUSER: "<%= s.db_user %>"
<% else -%>
    RAILS_DB_HOST: <%= s.svc %>-db
    RAILS_CACHE_DB_HOST: <%= s.svc %>-db
    PGHOST: <%= s.svc %>-db
<% end -%>
    CLIENT_BROWSER_API_URL: *client-url
<% if s.minio_storage? -%>
    UPLOAD_CDN_HOST: *client-url
    UPLOAD_USE_ASSET_CDN: "true"
    UPLOAD_MAPPED_HOST: *client-url
    MANIFOLD_SETTINGS_STORAGE_PRIMARY: s3
    MANIFOLD_SETTINGS_STORAGE_PRIMARY_PREFIX: store
    MANIFOLD_SETTINGS_STORAGE_CACHE_PREFIX: cache
    MANIFOLD_SETTINGS_STORAGE_TUS_PREFIX: cache
    S3_ENDPOINT: "http://<%= s.svc %>-storage:9000"
    S3_FORCE_PATH_STYLE: "true"
    S3_REGION: us-east-1
    UPLOAD_BUCKET: <%= s.svc %>-storage
<% elsif s.s3_storage? -%>
    MANIFOLD_SETTINGS_STORAGE_PRIMARY: s3
    MANIFOLD_SETTINGS_STORAGE_PRIMARY_PREFIX: store
    MANIFOLD_SETTINGS_STORAGE_CACHE_PREFIX: cache
    MANIFOLD_SETTINGS_STORAGE_TUS_PREFIX: cache
    S3_ENDPOINT: "<%= s.s3_endpoint %>"
    S3_FORCE_PATH_STYLE: "<%= s.s3_force_path_style %>"
    S3_REGION: "<%= s.s3_region %>"
    UPLOAD_BUCKET: "<%= s.s3_bucket %>"
<% end -%>
<% if s.s3_compatible? -%>
  secret:
    - SECRET_KEY_BASE
    - RAILS_SECRET_KEY
    - RAILS_DB_PASS
    - RAILS_CACHE_DB_PASS
    - S3_ACCESS_KEY_ID
    - S3_SECRET_ACCESS_KEY
    - PGPASSWORD
<% end -%>
<% if s.arch != "amd64" -%>

builder:
  arch: <%= s.arch %>
<% end -%>

accessories:
<% if s.local_database? -%>
  db:
    service: <%= s.svc %>-db
    image: postgres:15-alpine
    host: *server-ip
    env:
      clear:
        POSTGRES_USER: manifold
        POSTGRES_DB: manifold_production
      secret:
        - POSTGRES_PASSWORD
    directories:
      - data:/var/lib/postgresql/data
    options:
      shm-size: 2g
<% end -%>
<% if s.minio_storage? -%>
  storage:
    service: <%= s.svc %>-storage
    image: minio/minio:RELEASE.2022-09-25T15-44-53Z
    host: *server-ip
    proxy:
      host: *domain
      app_port: 9000
      path_prefixes:
        - /<%= s.svc %>-storage
      strip_path_prefix: false
      healthcheck:
        path: /minio/health/live
    options:
      publish: "9001:9001"
    cmd: server /data --console-address ":9001"
    env:
      secret:
        - MINIO_ROOT_USER
        - MINIO_ROOT_PASSWORD
    directories:
      - data:/data
<% end -%>
  client:
    service: <%= s.svc %>-client
    host: *server-ip
    proxy:
      host: *domain
<% if s.ssl_disabled? -%>
      ssl: false
<% end -%>
    env:
      clear:
        DOMAIN: *domain
<% if s.ssl_disabled? -%>
        SSL_ENABLED: "false"
<% end -%>
        CLIENT_URL: *client-url
        CLIENT_BROWSER_API_URL: *client-url
        CLIENT_BROWSER_API_CABLE_URL: *client-url
        CLIENT_SERVER_API_URL: "http://<%= s.svc %>-api:3011"
