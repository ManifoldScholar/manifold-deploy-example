<% effective_domain = domain.empty? ? server_ip : domain -%>
<% client_url = domain.empty? ? "http://#{server_ip}" : "https://#{domain}" -%>
<% svc = "manifold-#{dest}" -%>
# =============================================================================
# Instance-specific overrides — generated by bin/deploy setup
# =============================================================================
#
# This file deep-merges on top of deploy.yml.
# Regenerate with: bin/deploy setup -d <%= dest %>
#
# All Kamal commands require -d <%= dest %>:
#   kamal setup -d <%= dest %>
#   kamal deploy -d <%= dest %>
#
# Secrets: .kamal/secrets.<%= dest %>
#
# bin/deploy setup: server_ip=<%= server_ip %> domain=<%= domain %> arch=<%= arch %> storage=<%= storage %>
# =============================================================================

x-server-ip:  &server-ip  "<%= server_ip %>"
x-domain:     &domain      "<%= effective_domain %>"
x-client-url: &client-url  "<%= client_url %>"

servers:
  web:
    hosts:
      - *server-ip
<% if storage == "minio" -%>
    cmd: bash -c "bin/ensure-bucket && bin/ensure-db && bin/rails manifold:upgrade && exec bin/puma -C config/puma.rb"
<% end -%>
    options:
      network-alias: <%= svc %>-api
<% if storage == "local" -%>
      volume: <%= dest %>-uploads:/srv/app/public/system
<% end -%>
  worker:
    hosts:
      - *server-ip
<% if storage == "local" -%>
    options:
      volume: <%= dest %>-uploads:/srv/app/public/system
<% end -%>

proxy:
  host: *domain

env:
  clear:
<% if domain.empty? -%>
    SSL_ENABLED: "false"
<% end -%>
    DOMAIN: *domain
    RAILS_DB_HOST: <%= svc %>-db
    RAILS_CACHE_DB_HOST: <%= svc %>-db
    PGHOST: <%= svc %>-db
    CLIENT_BROWSER_API_URL: *client-url
    UPLOAD_CDN_HOST: *client-url
<% if storage == "minio" -%>
    UPLOAD_USE_ASSET_CDN: "true"
    UPLOAD_MAPPED_HOST: *client-url
    MANIFOLD_SETTINGS_STORAGE_PRIMARY: s3
    MANIFOLD_SETTINGS_STORAGE_PRIMARY_PREFIX: store
    MANIFOLD_SETTINGS_STORAGE_CACHE_PREFIX: cache
    MANIFOLD_SETTINGS_STORAGE_TUS_PREFIX: cache
    S3_ENDPOINT: "http://<%= svc %>-storage:9000"
    S3_FORCE_PATH_STYLE: "true"
    S3_REGION: us-east-1
    UPLOAD_BUCKET: <%= svc %>-storage
  secret:
    - SECRET_KEY_BASE
    - RAILS_SECRET_KEY
    - RAILS_DB_PASS
    - RAILS_CACHE_DB_PASS
    - S3_ACCESS_KEY_ID
    - S3_SECRET_ACCESS_KEY
    - PGPASSWORD
<% end -%>
<% if arch != "amd64" -%>

builder:
  arch: <%= arch %>
<% end -%>

accessories:
  db:
    service: <%= svc %>-db
    host: *server-ip
<% if storage == "minio" -%>
  storage:
    service: <%= svc %>-storage
    image: minio/minio:RELEASE.2022-09-25T15-44-53Z
    host: *server-ip
    proxy:
      host: *domain
      app_port: 9000
      path_prefixes:
        - /<%= svc %>-storage
      strip_path_prefix: false
      healthcheck:
        path: /minio/health/live
    options:
      publish: "9001:9001"
    cmd: server /data --console-address ":9001"
    env:
      secret:
        - MINIO_ROOT_USER
        - MINIO_ROOT_PASSWORD
    directories:
      - data:/data
<% end -%>
  client:
    service: <%= svc %>-client
    host: *server-ip
    proxy:
      host: *domain
<% if domain.empty? -%>
      ssl: false
<% end -%>
    env:
      clear:
        DOMAIN: *domain
<% if domain.empty? -%>
        SSL_ENABLED: "false"
<% end -%>
        CLIENT_URL: *client-url
        CLIENT_BROWSER_API_URL: *client-url
        CLIENT_BROWSER_API_CABLE_URL: *client-url
        CLIENT_SERVER_API_URL: "http://<%= svc %>-api:3011"
