#!/usr/bin/env ruby
#
# Show the state of everything on the kamal host:
# containers, volumes, images, disk usage, and kamal-proxy.
#
# Usage:
#   bin/remote-status -d <destination>
#
require_relative "remote-lib"

host, ssh_user, _, _ = resolve_host_from_argv

ssh_exec host, ssh_user, <<~BASH
  echo "=== Containers ==="
  docker ps -a --format 'table {{.Names}}\t{{.Status}}\t{{.Image}}'

  echo ""
  echo "=== Volumes ==="
  docker volume ls --format 'table {{.Name}}\t{{.Driver}}'

  echo ""
  echo "=== Images ==="
  docker image ls --format 'table {{.Repository}}\t{{.Tag}}\t{{.Size}}'

  echo ""
  echo "=== Disk (data directories) ==="
  du -sh manifold-* 2>/dev/null || echo "No data directories"

  echo ""
  echo "=== kamal-proxy ==="
  if docker ps --filter name=kamal-proxy --format '{{.Names}}' | grep -q kamal-proxy; then
    docker exec kamal-proxy kamal-proxy status 2>/dev/null || echo "kamal-proxy running (status command not available)"
  else
    echo "kamal-proxy is not running"
  fi
BASH
