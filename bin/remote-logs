#!/usr/bin/env ruby
#
# Tail logs from a container on the kamal host.
#
# Usage:
#   bin/remote-logs -d <destination> <container> [docker-logs-flags]
#
# Container shortcuts:
#   api, web    -> the running kamal app container
#   client      -> manifold-<dest>-client
#   db          -> manifold-<dest>-db
#   storage     -> manifold-<dest>-storage
#   worker      -> the running kamal worker container
#   proxy       -> kamal-proxy
#
# Examples:
#   bin/remote-logs -d zdtest api
#   bin/remote-logs -d zdtest client
#   bin/remote-logs -d zdtest db --tail 50 --no-follow
#
require_relative "remote-lib"

host, ssh_user, dest, args = resolve_host_from_argv

container = args.shift

if container.nil?
  warn "Usage: bin/remote-logs -d <destination> <container> [docker-logs-flags]"
  warn ""
  warn "Containers: api, worker, client, db, storage, proxy"
  exit 1
end

# Default to --tail 100 -f if no flags given
log_flags = args.empty? ? "--tail 100 -f" : args.join(" ")

prefix = "manifold-#{dest}"

# Map shortcut names to container resolution commands
resolve = case container
  when "api", "web"
    "docker ps --filter label=service=manifold --filter label=destination=#{dest} --filter label=role=web --format '{{.Names}}' | head -1"
  when "worker"
    "docker ps --filter label=service=manifold --filter label=destination=#{dest} --filter label=role=worker --format '{{.Names}}' | head -1"
  when "client"  then "echo #{prefix}-client"
  when "db"      then "echo #{prefix}-db"
  when "storage" then "echo #{prefix}-storage"
  when "proxy"   then "echo kamal-proxy"
  else "echo #{container}"
  end

ssh_exec host, ssh_user, <<~BASH
  CONTAINER_NAME=$(#{resolve})
  if [ -z "$CONTAINER_NAME" ]; then
    echo "No matching container found" >&2
    exit 1
  fi
  docker logs $CONTAINER_NAME #{log_flags}
BASH
