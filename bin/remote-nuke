#!/usr/bin/env ruby
#
# Completely remove a Manifold deployment from the server.
#
# Removes accessories first (while kamal-proxy is still running),
# then removes the app. Falls back to manual Docker cleanup
# if kamal commands fail (e.g. proxy already gone from a prior failed remove).
#
# This only removes the specified destination. Other destinations on the
# same host, kamal-proxy, and the shared .kamal directory are left intact.
#
# Usage:
#   bin/remote-nuke -d <destination>
#
require_relative "remote-lib"

host, ssh_user, dest, _ = resolve_host_from_argv

# Detect accessories from the merged kamal config for this destination.
base = parse_config("config/deploy.yml")
dest_config = parse_config("config/deploy.#{dest}.yml")
merged_accessories = (base["accessories"] || {}).merge(dest_config["accessories"] || {})
ACCESSORIES = merged_accessories.keys
PREFIX = "manifold-#{dest}"
CONTAINERS  = ACCESSORIES.map { |a| "#{PREFIX}-#{a}" }

puts "This will completely remove the Manifold deployment '#{dest}' from #{host}."
puts "All containers, volumes, and data directories for this destination will be deleted."
puts "Data that has not been backed up will be lost. Are you sure you want to do this?"
print "\nType 'yes' to confirm: "
confirm = $stdin.gets&.strip
unless confirm == "yes"
  puts "Aborted."
  exit 1
end

puts ""

# Step 1: Try the clean kamal path (accessories first, then app)
puts "==> Removing accessories via kamal..."
all_ok = true
ACCESSORIES.each do |name|
  puts "    Removing #{name}..."
  unless system("kamal", "accessory", "remove", name, "-d", dest, "--confirmed")
    all_ok = false
  end
end

puts "==> Removing app via kamal..."
unless system("kamal", "app", "remove", "-d", dest)
  all_ok = false
end

# Step 2: If anything failed, clean up remaining containers directly
unless all_ok
  puts ""
  puts "==> Kamal cleanup incomplete, removing remaining containers directly..."
  system("ssh", "#{ssh_user}@#{host}",
    "docker rm -f #{CONTAINERS.join(' ')} 2>/dev/null; " \
    "docker container prune -f --filter label=service=manifold --filter label=destination=#{dest} 2>/dev/null; " \
    "true"
  )
end

# Step 3: Clean up volumes and data directories for this destination only
puts ""
puts "==> Cleaning up volumes and data directories..."
system("ssh", "#{ssh_user}@#{host}", <<~BASH)
  docker volume rm #{dest}-uploads 2>/dev/null
  rm -rf #{PREFIX}-* 2>/dev/null
  true
BASH

# Step 4: Verify nothing is left
puts ""
puts "==> Verifying cleanup..."
remaining = `ssh #{ssh_user}@#{host} "docker ps -a --format '{{.Names}}' | grep -E '#{PREFIX}'"`.strip

if remaining.empty?
  puts "==> Destination '#{dest}' removed."
  puts ""
  puts "To redeploy: kamal setup -d #{dest}"
else
  puts "==> Warning: some containers remain:"
  puts remaining
  puts ""
  puts "Remove manually: ssh #{ssh_user}@#{host} \"docker rm -f #{remaining.split.join(' ')}\""
end
