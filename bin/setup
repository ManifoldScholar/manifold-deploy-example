#!/usr/bin/env ruby
#
# Interactive setup wizard for Manifold deployment.
#
# Generates:
#   config/deploy.<dest>.yml   — destination config (deep-merges on deploy.yml)
#   .kamal/secrets.<dest>      — secrets file
#
# Usage:
#   bin/setup                  # New destination (interactive)
#   bin/setup -d <dest>        # Edit existing destination (interactive, pre-filled)
#
require "erb"
require "securerandom"
require "fileutils"

TEMPLATES_DIR = File.expand_path("../config/templates", __dir__)

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def prompt(label, default: nil, required: false, validate: nil)
  suffix = default ? " [#{default}]" : ""
  loop do
    print "#{label}#{suffix}: "
    input = $stdin.gets&.strip
    value = (input.nil? || input.empty?) ? default : input

    if required && (value.nil? || value.empty?)
      puts "  This field is required."
      next
    end

    if validate && value && !value.empty?
      error = validate.call(value)
      if error
        puts "  #{error}"
        next
      end
    end

    return value.to_s
  end
end

def prompt_choice(label, choices, default:)
  display = choices.map { |c| c == default ? c.upcase : c }.join("/")
  loop do
    print "#{label} [#{display}]: "
    input = $stdin.gets&.strip&.downcase
    value = (input.nil? || input.empty?) ? default : input
    return value if choices.include?(value)
    puts "  Please enter one of: #{choices.join(', ')}"
  end
end

def prompt_yes_no(label, default: "y")
  loop do
    d = default == "y" ? "Y/n" : "y/N"
    print "#{label} [#{d}]: "
    input = $stdin.gets&.strip&.downcase
    value = (input.nil? || input.empty?) ? default : input
    return value == "y" if %w[y n].include?(value)
    puts "  Please enter y or n."
  end
end

def generate_hex(bytes = 64)
  SecureRandom.hex(bytes)
end

def generate_password(length = 32)
  SecureRandom.alphanumeric(length)
end

IPV4_REGEX = /\A(\d{1,3}\.){3}\d{1,3}\z/

def validate_ip(value)
  return "Invalid IPv4 address." unless value.match?(IPV4_REGEX)
  parts = value.split(".").map(&:to_i)
  return "Invalid IPv4 address." unless parts.all? { |p| p >= 0 && p <= 255 }
  nil
end

def render_template(template_file, binding_obj)
  template = File.read(File.join(TEMPLATES_DIR, template_file))
  ERB.new(template, trim_mode: "-").result(binding_obj)
end

# Parse the "# bin/setup: key=val key=val" comment from a deploy config file.
def read_saved_settings(deploy_file)
  File.foreach(deploy_file) do |line|
    if line =~ /^# bin\/setup: (.+)$/
      pairs = $1.strip.split(/\s+/)
      return pairs.each_with_object({}) do |pair, h|
        k, v = pair.split("=", 2)
        h[k] = v
      end
    end
  end
  nil
end

# Parse secret values from a secrets file. Returns only raw values (not $VAR references).
def read_secrets(secrets_file)
  secrets = {}
  File.foreach(secrets_file) do |line|
    line = line.strip
    next if line.empty? || line.start_with?("#")
    if line =~ /\A([A-Z_]+)=(.+)\z/
      key, val = $1, $2
      secrets[key] = val unless val.start_with?("$")
    end
  end
  secrets
end

# ---------------------------------------------------------------------------
# Parse args
# ---------------------------------------------------------------------------

dest = nil
i = 0
while i < ARGV.length
  if ARGV[i] == "-d"
    dest = ARGV[i + 1]
    i += 2
  else
    i += 1
  end
end

# ---------------------------------------------------------------------------
# Load saved settings for a destination
# ---------------------------------------------------------------------------

def load_saved(dest)
  saved = nil
  saved_secrets = nil

  deploy_file = "config/deploy.#{dest}.yml"
  secrets_file = ".kamal/secrets.#{dest}"

  if File.exist?(deploy_file)
    saved = read_saved_settings(deploy_file)
    unless saved
      warn "Warning: No saved settings found in #{deploy_file}. Starting fresh."
    end
  end

  if File.exist?(secrets_file)
    saved_secrets = read_secrets(secrets_file)
  end

  [saved, saved_secrets]
end

saved, saved_secrets = dest ? load_saved(dest) : [nil, nil]

# ---------------------------------------------------------------------------
# Interactive prompts
# ---------------------------------------------------------------------------

puts ""
puts "Manifold Deployment Setup"
puts "=" * 40
puts ""
if saved
  puts "Editing destination '#{dest}'. Press enter to keep current values."
else
  puts "This wizard generates the configuration files needed to deploy Manifold"
  puts "to your server. You can re-run it at any time to regenerate them."
end
puts ""

# -- Gather inputs ----------------------------------------------------------

unless dest
  dest = prompt("Destination name", default: "production")
  saved, saved_secrets = load_saved(dest)
  if saved
    puts ""
    puts "Found existing config for '#{dest}'. Press enter to keep current values."
    puts ""
  end
end

server_ip = prompt("Server IP address",
  default: saved&.dig("server_ip"),
  required: true,
  validate: method(:validate_ip))

domain = prompt("Domain name (blank = use IP, no SSL)",
  default: saved&.dig("domain") || "")

arch = prompt_choice("Server architecture", %w[amd64 arm64],
  default: saved&.dig("arch") || "amd64")

storage = prompt_choice("Storage backend", %w[local minio],
  default: saved&.dig("storage") || "local")

# -- Secrets ----------------------------------------------------------------

if saved_secrets
  # Reuse existing secrets by default
  secret_key_base     = saved_secrets["SECRET_KEY_BASE"] || ""
  postgres_password   = saved_secrets["POSTGRES_PASSWORD"] || ""
  minio_root_password = saved_secrets["MINIO_ROOT_PASSWORD"] || ""

  # Generate MinIO password if switching to minio and don't have one
  if storage == "minio" && minio_root_password.empty?
    minio_root_password = generate_password
    puts ""
    puts "Generated MINIO_ROOT_PASSWORD for new MinIO storage."
  end
else
  auto_secrets = prompt_yes_no("Auto-generate secrets?", default: "y")

  if auto_secrets
    secret_key_base = generate_hex(64)
    postgres_password = generate_password
    minio_root_password = storage == "minio" ? generate_password : ""
  else
    puts ""
    secret_key_base = prompt("SECRET_KEY_BASE", required: true)
    postgres_password = prompt("POSTGRES_PASSWORD", required: true)
    minio_root_password = storage == "minio" ? prompt("MINIO_ROOT_PASSWORD", required: true) : ""
  end
end

# -- Render templates -------------------------------------------------------

deploy_file = "config/deploy.#{dest}.yml"
secrets_file = ".kamal/secrets.#{dest}"

deploy_content = render_template("deploy.yml.erb", binding)
secrets_content = render_template("secrets.erb", binding)

# -- Write files ------------------------------------------------------------

FileUtils.mkdir_p(File.dirname(deploy_file))
FileUtils.mkdir_p(File.dirname(secrets_file))

File.write(deploy_file, deploy_content)
File.write(secrets_file, secrets_content)

# -- Summary ----------------------------------------------------------------

puts ""
puts "Files generated:"
puts "  #{deploy_file}"
puts "  #{secrets_file}"
puts ""

if domain.empty?
  puts "Note: No domain was set. SSL is disabled and the server will be"
  puts "accessible via http://#{server_ip}. You can add a domain later by"
  puts "re-running bin/setup -d #{dest}."
  puts ""
end

if storage == "local"
  puts "Storage: local filesystem (uploads persist in /srv/app/public/system)"
  puts "No MinIO or S3 configuration is needed."
elsif storage == "minio"
  puts "Storage: MinIO (S3-compatible object storage)"
  puts "The storage accessory will be deployed alongside the application."
end

puts ""
puts "Next steps:"
puts "  kamal setup -d #{dest}"
puts ""
